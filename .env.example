# Django
DJANGO_SECRET_KEY=change-me-to-a-long-random-string
DJANGO_DEBUG=False

# Database (PostgreSQL) — preferred for production (Liara)
DATABASE_URL=postgres://USER:PASSWORD@HOST:5432/DB_NAME

# Local PostgreSQL fallback (when DATABASE_URL is not set)
DB_NAME=level_haft_db
DB_USER=postgres
DB_PASSWORD=your-local-db-password
DB_HOST=localhost
DB_PORT=5432

# Site
SITE_URL=https://levelhaft.com

# SMS (Kavenegar — OTP & notifications)
KAVENEGAR_API=your-kavenegar-api-key

# Payment gateway (Pasargad / PEP)
PEP_USERNAME=your-pep-username
PEP_PASSWORD=your-pep-password
PEP_TERMINAL_NO=your-terminal-number

# Admin notifications
ADMIN_PHONE=09xxxxxxxxx
