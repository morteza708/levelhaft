{
  "app": "levelhaft-test",
  "platform": "django",
  "port": 80,
  "django": {
    "mirror": false,
    "pythonVersion": "3.12",
    "collectstatic": true,
    "modifySettings": true
  },
  "build": {
    "location": "iran"
  },
  "disks": [
    {
      "name": "staticfiles",
      "mountTo": "staticfiles/"
    },
    {
      "name": "media",
      "mountTo": "media/"
    }
  ]
}